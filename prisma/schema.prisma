generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  zipCode   String
  birthDate String
  createdAt DateTime @default(now())

  userStores      UserStore[]
  userRestaurants UserRestaurant[]
  visitLogs       VisitLog[]
  redemptions     OfferRedemption[]
}

model Store {
  id     Int    @id @default(autoincrement())
  name   String
  icon   String
  color  String
  points Int    @default(10)
  tier   String @default("Bronze")

  userStores UserStore[]
  offers     StoreOffer[]
}

model Restaurant {
  id          Int    @id @default(autoincrement())
  name        String
  icon        String
  color       String
  cuisine     String
  points      Int    @default(10)
  tier        String @default("Bronze")
  managerCode String @default("")

  userRestaurants UserRestaurant[]
  offers          RestaurantOffer[]
}

model UserStore {
  userId  Int
  storeId Int

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([userId, storeId])
}

model UserRestaurant {
  userId       Int
  restaurantId Int

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@id([userId, restaurantId])
}

// Tracks every QR scan at a store/restaurant — awards points
model VisitLog {
  id           Int      @id @default(autoincrement())
  userId       Int
  storeId      Int?
  restaurantId Int?
  pointsAwarded Int
  scannedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Tracks offer redemptions — prevents reuse
model OfferRedemption {
  id           Int      @id @default(autoincrement())
  userId       Int
  offerId      Int
  offerType    String   // "store" or "restaurant"
  qrPayload    String   @unique  // the full REDEEM-{offerId}-{userId}-{ts} string
  redeemedAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model StoreOffer {
  id          Int    @id @default(autoincrement())
  storeId     Int
  title       String
  description String
  discount    String
  expiry      String
  category    String

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

model RestaurantOffer {
  id           Int    @id @default(autoincrement())
  restaurantId Int
  title        String
  description  String
  discount     String
  expiry       String
  category     String

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
}
